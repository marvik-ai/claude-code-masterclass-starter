{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "autoMemoryEnabled": false,

  "enabledPlugins": {
    "superpowers@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": false,
    "agent-sdk-dev@claude-plugins-official": false
  },

  "permissions": {
    "allow": [
      "Bash(npm test)",
      "Bash(npm run dev)",
      "Bash(npm start)",
      "Bash(npm install)",
      "Bash(git diff*)",
      "Bash(git status)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git log*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)"
    ]
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; npx prettier --write \"$f\"; } 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "Formatting..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"[\" + (.session_id // \"?\") + \"] \" + (.tool_input.command // \"\")' >> /tmp/workshop-audit.log",
            "async": true
          }
        ]
      }
    ]
  }
}
